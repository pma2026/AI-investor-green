# Base path the app calls for the backend API. Leave UNSET to run on stub/demo
# data (no backend needed). In production (Azure Static Web Apps with a linked
# backend) set this to "/api" so calls are same-origin.
# VITE_API_BASE=/api

# Dev-only: proxy /api to a real backend during `npm run dev` (avoids CORS).
# Point at the deployed Function App or a local `func start`.
# VITE_API_PROXY=http://localhost:7071
